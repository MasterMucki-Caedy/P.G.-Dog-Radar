<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>P.G. Dog-Radar Â· Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a1628;--navy2:#122040;--gold:#d4a843;--gold2:#e8c060;
  --green:#22c55e;--red:#ef4444;--amber:#f59e0b;--blue:#3b82f6;--purple:#8b5cf6;--orange:#f97316;
  --bg:#f0f4f8;--card:#fff;--text:#1e293b;--sub:#64748b;--border:#e2e8f0;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

/* â”€â”€ TOPBAR â”€â”€ */
.topbar{background:var(--navy);padding:0 28px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(0,0,0,.4)}
.topbar-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:#fff;display:flex;align-items:center;gap:10px;text-decoration:none}
.topbar-logo span{background:var(--gold);color:var(--navy);font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px;letter-spacing:.05em}
.topbar-nav{display:flex;gap:6px}
.tnav{background:none;border:none;color:rgba(255,255,255,.45);font-size:12px;font-weight:700;padding:6px 13px;border-radius:8px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.tnav.active,.tnav:hover{background:rgba(255,255,255,.1);color:#fff}
.back-link{color:rgba(255,255,255,.35);font-size:12px;text-decoration:none;font-weight:700;transition:color .15s}
.back-link:hover{color:var(--gold)}

/* â”€â”€ LAYOUT â”€â”€ */
.main{max-width:1200px;margin:0 auto;padding:28px 24px}

/* â”€â”€ KPI CARDS â”€â”€ */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.kpi-grid{grid-template-columns:1fr 1fr}}
.kpi{background:var(--card);border-radius:14px;padding:18px 20px;box-shadow:0 1px 8px rgba(0,0,0,.07);border-left:4px solid transparent;transition:transform .15s}
.kpi:hover{transform:translateY(-2px)}
.kpi-label{font-size:10px;font-weight:700;color:var(--sub);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;font-family:'Syne',sans-serif}
.kpi-value{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--text);line-height:1}
.kpi-sub{font-size:11px;color:var(--sub);margin-top:5px}

/* â”€â”€ TABS â”€â”€ */
.tabs{display:flex;gap:4px;background:var(--card);border-radius:12px;padding:4px;margin-bottom:22px;box-shadow:0 1px 6px rgba(0,0,0,.06);width:fit-content}
.tab{padding:8px 18px;border-radius:9px;border:none;background:none;font-weight:700;font-size:12px;color:var(--sub);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;white-space:nowrap}
.tab.active{background:var(--navy);color:#fff}

/* â”€â”€ TABLE â”€â”€ */
.table-wrap{background:var(--card);border-radius:14px;box-shadow:0 1px 8px rgba(0,0,0,.07);overflow:hidden}
.table-head{display:grid;padding:11px 18px;border-bottom:1px solid var(--border);background:#f8fafc}
.table-row{display:grid;padding:12px 18px;border-bottom:1px solid var(--border);align-items:center;transition:background .1s}
.table-row:last-child{border-bottom:none}
.table-row:hover{background:#f8fafc}
.th{font-size:10px;font-weight:700;color:var(--sub);letter-spacing:.7px;text-transform:uppercase}
.td{font-size:13px;color:var(--text)}
.td.sub{color:var(--sub);font-size:11px}

/* Meldungen cols: icon | titel | standort | melder | status | datum | aktion */
.meldung-grid{grid-template-columns:36px 1fr 1fr 100px 90px 90px 80px}
@media(max-width:900px){.meldung-grid{grid-template-columns:36px 1fr 80px 80px 60px}}

/* Users cols: avatar | name | email | status | ghost | joined | aktion */
.user-grid{grid-template-columns:36px 1fr 1fr 90px 60px 90px 80px}
@media(max-width:900px){.user-grid{grid-template-columns:36px 1fr 90px 60px 60px}}

/* Posts cols: avatar | text | autor | likes | datum | aktion */
.post-grid{grid-template-columns:36px 2fr 120px 60px 90px 80px}
@media(max-width:900px){.post-grid{grid-template-columns:36px 2fr 60px 60px}}

/* â”€â”€ PILLS â”€â”€ */
.pill{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:700}
.pill-green{background:#dcfce7;color:#166534}
.pill-red{background:#fee2e2;color:#991b1b}
.pill-amber{background:#fef3c7;color:#713f12}
.pill-blue{background:#dbeafe;color:#1e40af}
.pill-gray{background:#f1f5f9;color:#475569}
.pill-purple{background:#ede9fe;color:#5b21b6}

/* â”€â”€ ACTION BTNS â”€â”€ */
.action-btn{border:none;border-radius:7px;padding:5px 10px;font-size:11px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.action-btn:hover{opacity:.85}
.btn-erledigt{background:#dcfce7;color:#166534}
.btn-delete{background:#fee2e2;color:#991b1b}
.btn-admin{background:#ede9fe;color:#5b21b6}

/* â”€â”€ SEARCH & FILTER â”€â”€ */
.toolbar{display:flex;gap:10px;align-items:center;margin-bottom:16px;flex-wrap:wrap}
.search-inp{flex:1;min-width:180px;border:1.5px solid var(--border);border-radius:10px;padding:8px 13px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:border .15s;background:#fff}
.search-inp:focus{border-color:var(--gold)}
.filter-sel{border:1.5px solid var(--border);border-radius:10px;padding:8px 12px;font-size:12px;font-family:'DM Sans',sans-serif;outline:none;background:#fff;cursor:pointer;color:var(--text)}
.refresh-btn{background:var(--navy);color:var(--gold);border:none;border-radius:10px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:6px;transition:opacity .15s}
.refresh-btn:hover{opacity:.85}

/* â”€â”€ LOADING / EMPTY â”€â”€ */
.loading{text-align:center;padding:40px;color:var(--sub);font-size:14px}
.loading .spinner{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 12px}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{text-align:center;padding:48px 20px;color:var(--sub)}
.empty-icon{font-size:40px;margin-bottom:10px}

/* â”€â”€ TOAST â”€â”€ */
.toast-wrap{position:fixed;bottom:24px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:999}
.toast-item{background:var(--navy);color:#fff;padding:11px 18px;border-radius:12px;font-size:13px;font-weight:700;box-shadow:0 4px 20px rgba(0,0,0,.3);animation:slideIn .25s ease;display:flex;align-items:center;gap:8px}
@keyframes slideIn{from{transform:translateX(40px);opacity:0}to{transform:translateX(0);opacity:1}}
.toast-item.success{border-left:3px solid var(--green)}
.toast-item.error{border-left:3px solid var(--red)}
.toast-item.info{border-left:3px solid var(--gold)}

/* â”€â”€ STATS CHART â”€â”€ */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px}
@media(max-width:700px){.chart-grid{grid-template-columns:1fr}}
.chart-card{background:var(--card);border-radius:14px;padding:20px;box-shadow:0 1px 8px rgba(0,0,0,.07)}
.chart-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);margin-bottom:16px}
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.bar-label{font-size:11px;color:var(--sub);width:130px;flex-shrink:0}
.bar-track{flex:1;height:10px;background:#f1f5f9;border-radius:20px;overflow:hidden}
.bar-fill{height:100%;border-radius:20px;transition:width .6s ease}
.bar-count{font-size:11px;font-weight:700;color:var(--text);width:24px;text-align:right}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <a class="topbar-logo" href="index.html">
    ðŸ“¡ P.G. Dog-Radar <span>ADMIN</span>
  </a>
  <div class="topbar-nav">
    <button class="tnav active" id="tnav-dashboard" onclick="showSection('dashboard')">ðŸ“Š Dashboard</button>
    <button class="tnav" id="tnav-meldungen" onclick="showSection('meldungen')">âš ï¸ Meldungen</button>
    <button class="tnav" id="tnav-posts" onclick="showSection('posts')">ðŸ“° Posts</button>
    <button class="tnav" id="tnav-users" onclick="showSection('users')">ðŸ‘¥ Nutzer</button>
  </div>
  <a class="back-link" href="app.html">â† Zur App</a>
</div>

<div class="main">

  <!-- â•â•â•â•â•â•â•â•â•â• DASHBOARD â•â•â•â•â•â•â•â•â•â• -->
  <div id="sec-dashboard">
    <div style="margin-bottom:20px">
      <h1 style="font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--text)">Dashboard</h1>
      <div style="font-size:12px;color:var(--sub);margin-top:3px" id="lastRefresh">Wird geladenâ€¦</div>
    </div>

    <!-- KPIs -->
    <div class="kpi-grid">
      <div class="kpi" style="border-color:var(--red)">
        <div class="kpi-label">Meldungen offen</div>
        <div class="kpi-value" id="kpi-offen">â€”</div>
        <div class="kpi-sub">Warten auf Bearbeitung</div>
      </div>
      <div class="kpi" style="border-color:var(--green)">
        <div class="kpi-label">Meldungen heute</div>
        <div class="kpi-value" id="kpi-heute">â€”</div>
        <div class="kpi-sub">Letzte 24 Stunden</div>
      </div>
      <div class="kpi" style="border-color:var(--blue)">
        <div class="kpi-label">Registrierte Nutzer</div>
        <div class="kpi-value" id="kpi-users">â€”</div>
        <div class="kpi-sub">Gesamt in DB</div>
      </div>
      <div class="kpi" style="border-color:var(--gold)">
        <div class="kpi-label">Community Posts</div>
        <div class="kpi-value" id="kpi-posts">â€”</div>
        <div class="kpi-sub">Gesamt verÃ¶ffentlicht</div>
      </div>
    </div>

    <!-- Charts -->
    <div class="chart-grid">
      <div class="chart-card">
        <div class="chart-title">âš ï¸ Meldungen nach Typ</div>
        <div id="chart-types"><div class="loading"><div class="spinner"></div>Ladenâ€¦</div></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">ðŸ“‹ Status-Ãœbersicht</div>
        <div id="chart-status"><div class="loading"><div class="spinner"></div>Ladenâ€¦</div></div>
      </div>
    </div>

    <!-- Neueste Meldungen -->
    <div class="chart-card" style="margin-bottom:0">
      <div class="chart-title">ðŸ• Neueste Meldungen</div>
      <div id="recent-meldungen"><div class="loading"><div class="spinner"></div>Ladenâ€¦</div></div>
    </div>
  </div>

  <!-- â•â•â•â•â•â•â•â•â•â• MELDUNGEN â•â•â•â•â•â•â•â•â•â• -->
  <div id="sec-meldungen" style="display:none">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px">
      <h1 style="font-family:'Syne',sans-serif;font-size:22px;font-weight:800">âš ï¸ Meldungen</h1>
    </div>
    <div class="toolbar">
      <input class="search-inp" id="meldung-search" placeholder="ðŸ” Suchenâ€¦" oninput="filterMeldungen()">
      <select class="filter-sel" id="meldung-filter" onchange="filterMeldungen()">
        <option value="">Alle Status</option>
        <option value="offen">ðŸ”´ Offen</option>
        <option value="bestaetigt">âœ… BestÃ¤tigt</option>
        <option value="erledigt">âœ… Erledigt</option>
      </select>
      <select class="filter-sel" id="meldung-type-filter" onchange="filterMeldungen()">
        <option value="">Alle Typen</option>
        <option value="muell_voll">ðŸ—‘ï¸ MÃ¼lleimer voll</option>
        <option value="beutel_leer">ðŸ§» Beutelspender leer</option>
        <option value="getraenke_leer">ðŸ’§ TrÃ¤nke leer</option>
        <option value="giftkoeder">â˜ ï¸ GiftkÃ¶der</option>
        <option value="hund_verloren">ðŸ” Hund verloren</option>
        <option value="angriff">âš¡ Angriff</option>
        <option value="sonstiges">ðŸ“ Sonstiges</option>
      </select>
      <button class="refresh-btn" onclick="loadAll()">ðŸ”„ Aktualisieren</button>
    </div>
    <div class="table-wrap">
      <div class="table-head meldung-grid">
        <div class="th"></div>
        <div class="th">Titel / Ort</div>
        <div class="th">Standort</div>
        <div class="th">Melder</div>
        <div class="th">Status</div>
        <div class="th">Datum</div>
        <div class="th">Aktion</div>
      </div>
      <div id="meldungen-body"><div class="loading"><div class="spinner"></div>Meldungen werden geladenâ€¦</div></div>
    </div>
  </div>

  <!-- â•â•â•â•â•â•â•â•â•â• POSTS â•â•â•â•â•â•â•â•â•â• -->
  <div id="sec-posts" style="display:none">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px">
      <h1 style="font-family:'Syne',sans-serif;font-size:22px;font-weight:800">ðŸ“° Community Posts</h1>
    </div>
    <div class="toolbar">
      <input class="search-inp" id="post-search" placeholder="ðŸ” Suchenâ€¦" oninput="filterPosts()">
      <select class="filter-sel" id="post-type-filter" onchange="filterPosts()">
        <option value="">Alle Typen</option>
        <option value="normal">ðŸ’¬ Normal</option>
        <option value="meldung">âš ï¸ Meldung</option>
        <option value="warnung">ðŸš¨ Warnung</option>
        <option value="event">ðŸ“… Event</option>
      </select>
      <button class="refresh-btn" onclick="loadAll()">ðŸ”„ Aktualisieren</button>
    </div>
    <div class="table-wrap">
      <div class="table-head post-grid">
        <div class="th"></div>
        <div class="th">Text</div>
        <div class="th">Autor</div>
        <div class="th">â¤ï¸ Likes</div>
        <div class="th">Datum</div>
        <div class="th">Aktion</div>
      </div>
      <div id="posts-body"><div class="loading"><div class="spinner"></div>Posts werden geladenâ€¦</div></div>
    </div>
  </div>

  <!-- â•â•â•â•â•â•â•â•â•â• USERS â•â•â•â•â•â•â•â•â•â• -->
  <div id="sec-users" style="display:none">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px">
      <h1 style="font-family:'Syne',sans-serif;font-size:22px;font-weight:800">ðŸ‘¥ Nutzer</h1>
    </div>
    <div class="toolbar">
      <input class="search-inp" id="user-search" placeholder="ðŸ” Suchenâ€¦" oninput="filterUsers()">
      <select class="filter-sel" id="user-role-filter" onchange="filterUsers()">
        <option value="">Alle Rollen</option>
        <option value="admin">ðŸ‘‘ Admin</option>
        <option value="user">ðŸ‘¤ User</option>
      </select>
      <button class="refresh-btn" onclick="loadAll()">ðŸ”„ Aktualisieren</button>
    </div>
    <div class="table-wrap">
      <div class="table-head user-grid">
        <div class="th"></div>
        <div class="th">Hund / Name</div>
        <div class="th">E-Mail</div>
        <div class="th">Status</div>
        <div class="th">Ghost</div>
        <div class="th">Registriert</div>
        <div class="th">Aktion</div>
      </div>
      <div id="users-body"><div class="loading"><div class="spinner"></div>Nutzer werden geladenâ€¦</div></div>
    </div>
  </div>

</div>

<!-- TOAST CONTAINER -->
<div class="toast-wrap" id="toastWrap"></div>

<script>
/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   CONFIG
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
var API = 'https://base44.app/api/apps/69b33f5b68f33085d59e7f78/entities';
var TOKEN = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI2Zjg2YTU2ZC0zMGE1LTRmYjItOTdmZS1hZDA0ODgzYjQ0MjIiLCJjbGllbnRfaWQiOiI2Zjg2YTU2ZC0zMGE1LTRmYjItOTdmZS1hZDA0ODgzYjQ0MjIiLCJhcHBfaWQiOiI2OWIzM2Y1YjY4ZjMzMDg1ZDU5ZTdmNzgiLCJhdWQiOiJiYXNlNDRfYXBpIiwic2NvcGUiOiJhcHAuYWNjZXNzIiwiZXhwIjoxNzczMzU5OTk5LCJpYXQiOjE3NzMzNTYzOTl9.7yy2x1rlIa6RJwK_N1i_ZwvsTInFuBdqbPKJL4qo_l0';

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   STATE
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
var allMeldungen = [];
var allPosts     = [];
var allUsers     = [];

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   HTTP
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
async function api(method, path, body) { path = path.replace(//+$/, '');
  var opts = { method, headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+TOKEN } };
  if (body) opts.body = JSON.stringify(body);
  var res = await fetch(API + path, opts);
  if (!res.ok) throw new Error(res.status);
  var txt = await res.text();
  return txt ? JSON.parse(txt) : null;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   LOAD
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
async function loadAll() {
  try {
    var [meldungen, posts, users] = await Promise.all([
      api('GET', '/Meldung?_sort=-created_date&_limit=200'),
      api('GET', '/Post?_sort=-created_date&_limit=200'),
      api('GET', '/User?_sort=-created_date&_limit=200')
    ]);
    allMeldungen = meldungen || [];
    allPosts     = posts     || [];
    allUsers     = users     || [];
    updateKPIs();
    renderCharts();
    renderRecentMeldungen();
    renderMeldungen();
    renderPosts();
    renderUsers();
    document.getElementById('lastRefresh').textContent =
      'Zuletzt aktualisiert: ' + new Date().toLocaleTimeString('de-DE');
    toast('âœ… Daten geladen', 'success');
  } catch(e) {
    toast('âš ï¸ Fehler beim Laden: '+e.message, 'error');
  }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   KPIS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
function updateKPIs() {
  var offen  = allMeldungen.filter(function(m){ return m.status === 'offen'; }).length;
  var cutoff = Date.now() - 86400000;
  var heute  = allMeldungen.filter(function(m){ return new Date(m.created_date) > cutoff; }).length;
  document.getElementById('kpi-offen').textContent  = offen;
  document.getElementById('kpi-heute').textContent  = heute;
  document.getElementById('kpi-users').textContent  = allUsers.length;
  document.getElementById('kpi-posts').textContent  = allPosts.length;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   CHARTS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
var TYPE_LABELS = {
  muell_voll:'ðŸ—‘ï¸ MÃ¼lleimer voll', beutel_leer:'ðŸ§» Beutelspender leer',
  getraenke_leer:'ðŸ’§ TrÃ¤nke leer', giftkoeder:'â˜ ï¸ GiftkÃ¶der',
  hund_verloren:'ðŸ” Hund verloren', angriff:'âš¡ Angriff', sonstiges:'ðŸ“ Sonstiges'
};
var TYPE_COLORS = {
  muell_voll:'#78716c', beutel_leer:'#f97316', getraenke_leer:'#0ea5e9',
  giftkoeder:'#ef4444', hund_verloren:'#3b82f6', angriff:'#8b5cf6', sonstiges:'#94a3b8'
};

function renderCharts() {
  /* Types */
  var typeCounts = {};
  allMeldungen.forEach(function(m){ typeCounts[m.type] = (typeCounts[m.type]||0)+1; });
  var maxT = Math.max(1, ...Object.values(typeCounts));
  var typesHtml = Object.keys(typeCounts).length === 0
    ? '<div class="empty"><div class="empty-icon">ðŸ“­</div>Noch keine Meldungen</div>'
    : Object.entries(typeCounts).sort(function(a,b){return b[1]-a[1];}).map(function(e){
        return '<div class="bar-row">'+
          '<div class="bar-label">'+( TYPE_LABELS[e[0]]||e[0] )+'</div>'+
          '<div class="bar-track"><div class="bar-fill" style="width:'+(e[1]/maxT*100)+'%;background:'+(TYPE_COLORS[e[0]]||'#94a3b8')+'"></div></div>'+
          '<div class="bar-count">'+e[1]+'</div>'+
        '</div>';
      }).join('');
  document.getElementById('chart-types').innerHTML = typesHtml;

  /* Status */
  var statusCounts = {offen:0, bestaetigt:0, erledigt:0};
  allMeldungen.forEach(function(m){ if(statusCounts[m.status]!==undefined) statusCounts[m.status]++; });
  var maxS = Math.max(1, ...Object.values(statusCounts));
  var statusColors = {offen:'#ef4444', bestaetigt:'#f59e0b', erledigt:'#22c55e'};
  var statusLabels = {offen:'ðŸ”´ Offen', bestaetigt:'ðŸŸ¡ BestÃ¤tigt', erledigt:'âœ… Erledigt'};
  var statusHtml = Object.entries(statusCounts).map(function(e){
    return '<div class="bar-row">'+
      '<div class="bar-label">'+statusLabels[e[0]]+'</div>'+
      '<div class="bar-track"><div class="bar-fill" style="width:'+(e[1]/maxS*100)+'%;background:'+statusColors[e[0]]+'"></div></div>'+
      '<div class="bar-count">'+e[1]+'</div>'+
    '</div>';
  }).join('');
  document.getElementById('chart-status').innerHTML = statusHtml || '<div class="empty">Keine Daten</div>';
}

function renderRecentMeldungen() {
  var recent = allMeldungen.slice(0, 5);
  if (recent.length === 0) {
    document.getElementById('recent-meldungen').innerHTML = '<div class="empty"><div class="empty-icon">ðŸ“­</div>Noch keine Meldungen</div>';
    return;
  }
  document.getElementById('recent-meldungen').innerHTML = recent.map(function(m){
    return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)">'+
      '<span style="font-size:22px">'+(m.icon||'ðŸ“')+'</span>'+
      '<div style="flex:1"><div style="font-weight:700;font-size:13px">'+escHtml(m.titel)+'</div>'+
        '<div style="font-size:11px;color:var(--sub)">'+escHtml(m.standort)+' Â· '+(m.melder_name||'Anonym')+' Â· '+timeAgo(m.created_date)+'</div></div>'+
      statusPill(m.status)+
    '</div>';
  }).join('');
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   MELDUNGEN TABLE
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
function renderMeldungen(data) {
  var rows = data || filteredMeldungen();
  if (rows.length === 0) {
    document.getElementById('meldungen-body').innerHTML = '<div class="empty"><div class="empty-icon">ðŸ“­</div>Keine Meldungen gefunden</div>';
    return;
  }
  document.getElementById('meldungen-body').innerHTML = rows.map(function(m){
    return '<div class="table-row meldung-grid">'+
      '<div class="td" style="font-size:20px">'+(m.icon||'ðŸ“')+'</div>'+
      '<div class="td"><div style="font-weight:700;font-size:12px">'+escHtml(m.titel)+'</div><div class="sub">'+( TYPE_LABELS[m.type]||m.type )+'</div></div>'+
      '<div class="td sub">'+escHtml(m.standort||'â€”')+'</div>'+
      '<div class="td sub">'+(m.melder_avatar||'ðŸ•')+' '+(m.melder_name||'Anonym')+'</div>'+
      '<div class="td">'+statusPill(m.status)+'</div>'+
      '<div class="td sub">'+fmtDate(m.created_date)+'</div>'+
      '<div class="td" style="display:flex;gap:4px;flex-wrap:wrap">'+
        (m.status!=='erledigt' ? '<button class="action-btn btn-erledigt" onclick="erledigeM(\''+m.id+'\')">âœ… Erledigt</button>' : '')+
        '<button class="action-btn btn-delete" onclick="deleteM(\''+m.id+'\')">ðŸ—‘ï¸</button>'+
      '</div>'+
    '</div>';
  }).join('');
}
function filteredMeldungen() {
  var q  = (document.getElementById('meldung-search').value||'').toLowerCase();
  var st = document.getElementById('meldung-filter').value;
  var ty = document.getElementById('meldung-type-filter').value;
  return allMeldungen.filter(function(m){
    var matchQ  = !q  || (m.titel+m.standort+m.melder_name).toLowerCase().includes(q);
    var matchSt = !st || m.status === st;
    var matchTy = !ty || m.type   === ty;
    return matchQ && matchSt && matchTy;
  });
}
function filterMeldungen(){ renderMeldungen(); }

async function erledigeM(id) {
  try {
    await api('PUT', '/Meldung/'+id, {status:'erledigt'});
    var m = allMeldungen.find(function(x){return x.id===id;});
    if (m) m.status = 'erledigt';
    renderMeldungen(); updateKPIs(); renderCharts(); renderRecentMeldungen();
    toast('âœ… Meldung als erledigt markiert', 'success');
  } catch(e){ toast('âš ï¸ Fehler: '+e.message, 'error'); }
}
async function deleteM(id) {
  if (!confirm('Meldung wirklich lÃ¶schen?')) return;
  try {
    await api('DELETE', '/Meldung/'+id);
    allMeldungen = allMeldungen.filter(function(x){return x.id!==id;});
    renderMeldungen(); updateKPIs(); renderCharts(); renderRecentMeldungen();
    toast('ðŸ—‘ï¸ Meldung gelÃ¶scht', 'info');
  } catch(e){ toast('âš ï¸ Fehler: '+e.message, 'error'); }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   POSTS TABLE
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
function renderPosts(data) {
  var rows = data || filteredPosts();
  if (rows.length === 0) {
    document.getElementById('posts-body').innerHTML = '<div class="empty"><div class="empty-icon">ðŸ“­</div>Keine Posts gefunden</div>';
    return;
  }
  document.getElementById('posts-body').innerHTML = rows.map(function(p){
    return '<div class="table-row post-grid">'+
      '<div class="td" style="font-size:20px">'+(p.autor_avatar||'ðŸ•')+'</div>'+
      '<div class="td" style="font-size:12px;line-height:1.4;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+escHtml(p.text)+'">'+escHtml(p.text)+'</div>'+
      '<div class="td sub">'+escHtml(p.autor_name||'Anonym')+'<br>'+escHtml(p.standort||'Bremen')+'</div>'+
      '<div class="td" style="font-weight:700;color:var(--red)">â¤ï¸ '+(p.likes||0)+'</div>'+
      '<div class="td sub">'+fmtDate(p.created_date)+'</div>'+
      '<div class="td"><button class="action-btn btn-delete" onclick="deleteP(\''+p.id+'\')">ðŸ—‘ï¸ LÃ¶schen</button></div>'+
    '</div>';
  }).join('');
}
function filteredPosts() {
  var q  = (document.getElementById('post-search').value||'').toLowerCase();
  var ty = document.getElementById('post-type-filter').value;
  return allPosts.filter(function(p){
    var matchQ  = !q  || (p.text+p.autor_name).toLowerCase().includes(q);
    var matchTy = !ty || p.typ === ty;
    return matchQ && matchTy;
  });
}
function filterPosts(){ renderPosts(); }

async function deleteP(id) {
  if (!confirm('Post wirklich lÃ¶schen?')) return;
  try {
    await api('DELETE', '/Post/'+id);
    allPosts = allPosts.filter(function(x){return x.id!==id;});
    renderPosts(); updateKPIs();
    toast('ðŸ—‘ï¸ Post gelÃ¶scht', 'info');
  } catch(e){ toast('âš ï¸ Fehler: '+e.message, 'error'); }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   USERS TABLE
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
var STATUS_MAP = {friendly:'ðŸŸ¢ VertrÃ¤glich', notFriendly:'ðŸ”´ Nicht vertr.', inHeat:'ðŸŒ¸ LÃ¤ufig', keepDist:'ðŸŸ¡ Abstand'};

function renderUsers(data) {
  var rows = data || filteredUsers();
  if (rows.length === 0) {
    document.getElementById('users-body').innerHTML = '<div class="empty"><div class="empty-icon">ðŸ‘¥</div>Keine Nutzer gefunden</div>';
    return;
  }
  document.getElementById('users-body').innerHTML = rows.map(function(u){
    return '<div class="table-row user-grid">'+
      '<div class="td" style="font-size:20px">'+(u.avatar||'ðŸ•')+'</div>'+
      '<div class="td"><div style="font-weight:700;font-size:12px">'+(u.dog_name||u.full_name||'â€”')+'</div><div class="sub">'+rolePill(u.role)+'</div></div>'+
      '<div class="td sub" style="font-size:11px">'+(u.email||'â€”')+'</div>'+
      '<div class="td sub" style="font-size:11px">'+(STATUS_MAP[u.status]||'â€”')+'</div>'+
      '<div class="td">'+(u.ghost_mode ? '<span class="pill pill-purple">ðŸ‘» AN</span>' : '<span class="pill pill-gray">Aus</span>')+'</div>'+
      '<div class="td sub">'+fmtDate(u.created_date)+'</div>'+
      '<div class="td" style="display:flex;gap:4px;flex-wrap:wrap">'+
        (u.role!=='admin' ? '<button class="action-btn btn-admin" onclick="makeAdmin(\''+u.id+'\')">ðŸ‘‘ Admin</button>' : '')+
        '<button class="action-btn btn-delete" onclick="deleteU(\''+u.id+'\')">ðŸ—‘ï¸</button>'+
      '</div>'+
    '</div>';
  }).join('');
}
function filteredUsers() {
  var q  = (document.getElementById('user-search').value||'').toLowerCase();
  var ro = document.getElementById('user-role-filter').value;
  return allUsers.filter(function(u){
    var matchQ  = !q  || (u.email+u.dog_name+u.full_name).toLowerCase().includes(q);
    var matchRo = !ro || u.role === ro;
    return matchQ && matchRo;
  });
}
function filterUsers(){ renderUsers(); }

async function makeAdmin(id) {
  if (!confirm('Diesen Nutzer zum Admin machen?')) return;
  try {
    await api('PUT', '/User/'+id, {role:'admin'});
    var u = allUsers.find(function(x){return x.id===id;}); if(u) u.role='admin';
    renderUsers();
    toast('ðŸ‘‘ Nutzer ist jetzt Admin', 'success');
  } catch(e){ toast('âš ï¸ Fehler: '+e.message, 'error'); }
}
async function deleteU(id) {
  if (!confirm('Nutzer wirklich lÃ¶schen? Alle Daten werden entfernt.')) return;
  try {
    await api('DELETE', '/User/'+id);
    allUsers = allUsers.filter(function(x){return x.id!==id;});
    renderUsers(); updateKPIs();
    toast('ðŸ—‘ï¸ Nutzer gelÃ¶scht', 'info');
  } catch(e){ toast('âš ï¸ Fehler: '+e.message, 'error'); }
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SECTIONS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
function showSection(name) {
  ['dashboard','meldungen','posts','users'].forEach(function(s){
    document.getElementById('sec-'+s).style.display = s===name ? 'block' : 'none';
    document.getElementById('tnav-'+s).classList.toggle('active', s===name);
  });
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   HELPERS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
function statusPill(s) {
  if (s==='offen')      return '<span class="pill pill-red">ðŸ”´ Offen</span>';
  if (s==='bestaetigt') return '<span class="pill pill-amber">ðŸŸ¡ BestÃ¤tigt</span>';
  if (s==='erledigt')   return '<span class="pill pill-green">âœ… Erledigt</span>';
  return '<span class="pill pill-gray">'+s+'</span>';
}
function rolePill(r) {
  if (r==='admin') return '<span class="pill pill-purple">ðŸ‘‘ Admin</span>';
  return '<span class="pill pill-blue">ðŸ‘¤ User</span>';
}
function fmtDate(d) {
  if (!d) return 'â€”';
  return new Date(d).toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'});
}
function timeAgo(d) {
  if (!d) return 'â€”';
  var diff = Math.floor((Date.now()-new Date(d))/1000);
  if (diff<60) return 'Gerade eben';
  if (diff<3600) return 'Vor '+Math.floor(diff/60)+' Min';
  if (diff<86400) return 'Vor '+Math.floor(diff/3600)+' Std';
  return 'Vor '+Math.floor(diff/86400)+' Tagen';
}
function escHtml(s){
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

var toastTimers = {};
function toast(msg, type) {
  var wrap = document.getElementById('toastWrap');
  var el = document.createElement('div');
  el.className = 'toast-item ' + (type||'info');
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(function(){ if(el.parentNode) el.parentNode.removeChild(el); }, 3500);
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   INIT
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
loadAll();
// Auto-refresh alle 60 Sekunden
setInterval(loadAll, 60000);
</script>
</body>
